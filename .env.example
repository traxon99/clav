# Copy to .env (gitignored) and fill in your keys. Never commit the real .env
# file. Only Alpaca is required — everything below is optional and off by
# default; a fresh clone with no paid keys still runs the full loop
# technical-only (Epic 3 decision #5).

# Required: Alpaca *paper* trading API keys.
# Get these from https://app.alpaca.markets/paper/dashboard/overview
CLAV_ALPACA__API_KEY=your-alpaca-paper-key-id
CLAV_ALPACA__API_SECRET=your-alpaca-paper-secret-key

# Optional: Gemini API key (Epic 3). Without this, GeminiAnalyst always
# returns a neutral fallback (llm_signal=0) — safe to leave unset. Get a key
# at https://aistudio.google.com/apikey (the Gemini API free tier is usable
# on its own; the operator's complimentary Gemini Pro grant is a separate,
# additional allowance through ~mid-2027 — revisit before it lapses).
# CLAV_LLM__API_KEY=your-gemini-api-key

# Optional: NewsAPI key (Epic 3, Story 3.1). PAID product — off by default
# (sources.news.newsapi_enabled: false in config.yaml) even if a key is set
# here; flip that config flag too if you want to opt in.
# CLAV_NEWSAPI__API_KEY=your-newsapi-key

# Optional: shared token for clav-web's state-changing requests (Epic 3,
# Story 3.8). Off by default — a single operator on a private LAN/localhost
# needs no app password (epic decision #7). Only set this for defence-in-
# depth on a shared/untrusted network.
# CLAV_WEB__TOKEN=choose-a-long-random-string
